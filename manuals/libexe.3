.Dd June 11, 2026
.Dt LIBEXE 3
.Os
.Sh NAME
.Nm libexe.h
.Nd Library to access the executable (EXE) format
.Sh SYNOPSIS
.In libexe.h
.Pp
Support functions
.nf
.Ft const char *
.Fo libexe_get_version
.Fa "void"
.Fc
.fi
.nf
.Ft int
.Fo libexe_get_access_flags_read
.Fa "void"
.Fc
.fi
.nf
.Ft int
